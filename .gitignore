# =========================================================
# Root .gitignore for multi-module Java / Spring Boot repo
# =========================================================

# -----------------------------
# IntelliJ IDEA
# -----------------------------
.idea/
*.iml
*.ipr
*.iws
out/

# -----------------------------
# VS Code
# -----------------------------
.vscode/

# -----------------------------
# Eclipse
# -----------------------------
.project
.classpath
.settings/

# -----------------------------
# NetBeans
# -----------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# -----------------------------
# Build folders
# -----------------------------
target/
build/
bin/
out/

# -----------------------------
# Maven
# -----------------------------
.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# -----------------------------
# Gradle
# -----------------------------
.gradle/

# -----------------------------
# Logs
# -----------------------------
*.log
logs/

# -----------------------------
# OS generated files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Java compiled files
# -----------------------------
*.class
*.jar
*.war
*.ear

# Keep wrapper jar if needed
!gradle-wrapper.jar

# -----------------------------
# Test reports
# -----------------------------
surefire-reports/
failsafe-reports/

# -----------------------------
# Spring Boot
# -----------------------------
application-local.yml
application-dev.yml
application-secret.yml

# -----------------------------
# Environment files
# -----------------------------
.env
.env.*

# -----------------------------
# Kafka / Local runtime
# -----------------------------
kafka-logs/
zookeeper/
tmp/

# -----------------------------
# Coverage reports
# -----------------------------
coverage/
jacoco.exec
/site/jacoco/

# -----------------------------
# Generated sources
# -----------------------------
generated/
generated-sources/
generated-test-sources/

# -----------------------------
# Mac/Linux temp files
# -----------------------------
*~
*.swp

# -----------------------------
# Module specific ignores
# Applies to:
# 01_core-java
# 02_exception-logging
# 03_spring-boot-fundamentals
# 04_data-jpa
# 05_testing-junit-mockito
# 06_advanced-java
# 07_microservices
# 08_kafka-integration
# 09_system-design
# 10_coding-challenges
# 11_playground
# 12_data_structure_algorithms
# core-java
# jpa-practice
# kafka-streams
# reactive-programming
# springboot-basics
# testing
# -----------------------------

**/target/
**/build/
**/.idea/
**/*.iml
**/out/

# -----------------------------
# Optional:
# Keep README files tracked
# -----------------------------
!README.md